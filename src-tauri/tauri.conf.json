{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ragnarok Farmer",
  "version": "0.1.0",
  "identifier": "com.mpedro1996.ragnarokfarmer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:3000",
    "beforeBuildCommand": "npm run desktop:prepare"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ragnarok Farmer",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "bundle/app/**/*",
      "bundle/bin/**/*"
    ]
  }
}
